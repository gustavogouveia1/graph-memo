{
  "name": "graphmemo",
  "version": "0.1.0",
  "description": "CLI local para memoria persistente e knowledge graph do Graph-Memo.",
  "private": true,
  "main": "dist/cli/main.js",
  "bin": {
    "graphmemo": "dist/cli/main.js"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "dev:web": "tsx src/web/main.ts",
    "start": "node dist/cli/main.js",
    "start:web": "node dist/web/main.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "demo:reset": "bash ./scripts/reset-demo-fixture.sh",
    "quality": "bash ./scripts/run-quality.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gustavogouveia1/graph-memo.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gustavogouveia1/graph-memo/issues"
  },
  "homepage": "https://github.com/gustavogouveia1/graph-memo#readme",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
